rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isDM() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dm';
    }
    
    // Users collection - document ID MUST be the user's UID
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isAuthenticated() && (request.auth.uid == uid || isDM());
      allow delete: if isDM();
    }
    
    // Characters collection
    match /characters/{characterId} {
      // Anyone authenticated can read all characters
      allow read: if isAuthenticated();
      
      // Create: authenticated users can create characters
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid;
      
      // Update: DMs can update anything, players can update their own (except isDead and level).
      // Any authenticated user may change ONLY gp/items of any character (marketplace & trades).
      allow update: if isDM() ||
                      (isAuthenticated() &&
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.isDead == resource.data.isDead &&
                       request.resource.data.level == resource.data.level) ||
                      (isAuthenticated() &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['gp', 'items']));

      // Delete: only DMs
      allow delete: if isDM();
    }

    // Market catalog (guild shop)
    match /market_items/{itemId} {
      allow read: if isAuthenticated();
      allow create, delete: if isDM();
      // DM edits anything; players may only decrement stock when buying
      allow update: if isDM() ||
                      (isAuthenticated() &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']));
    }

    // Player-to-player sale listings
    match /market_listings/{listingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                      request.resource.data.sellerId == request.auth.uid;
      // Buyer marks sold, seller/DM cancels: keep to authenticated (friends' group)
      allow update: if isAuthenticated();
      allow delete: if isDM();
    }

    // Player-to-player trades
    match /trades/{tradeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                      request.resource.data.fromUserId == request.auth.uid;
      // The two involved parties (and DM) can resolve the trade
      allow update: if isAuthenticated() &&
                      (request.auth.uid == resource.data.fromUserId ||
                       request.auth.uid == resource.data.toUserId || isDM());
      allow delete: if isDM();
    }

    // Campaigns (containers for quests)
    match /campaigns/{campaignId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isDM();
    }

    // Notification feed (DM and players). Anyone can mark-as-read (readBy only).
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isDM() ||
                      (isAuthenticated() &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']));
      allow delete: if isDM();
    }

    // Maps: everyone authenticated can read; only DM can upload/edit/delete
    match /maps/{mapId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isDM();
    }

    // Audit log / ledger (read: DM only; append-only for players; DM can prune)
    match /audit_log/{entryId} {
      allow read: if isDM();
      allow create: if isAuthenticated() &&
                      request.resource.data.actorId == request.auth.uid;
      allow update: if false;
      allow delete: if isDM();
    }
    
    // Pending Changes collection
    match /pending_changes/{changeId} {
      // Read: owners and DMs
      allow read: if isAuthenticated() && 
                    (request.auth.uid == resource.data.requestedBy || isDM());
      
      // Create: players can create for their own characters
      allow create: if isAuthenticated() && 
                      request.resource.data.requestedBy == request.auth.uid &&
                      request.resource.data.status == 'pending';
      
      // Update: only DMs to approve/reject
      allow update: if isDM();
      
      // Delete: only DMs
      allow delete: if isDM();
    }
    
    // Quests collection
    match /quests/{questId} {
      // Read: everyone authenticated
      allow read: if isAuthenticated();
      
      // Create: only DMs
      allow create: if isDM();
      
      // Update: DMs can do anything, players can only modify participants
      allow update: if isDM() ||
                      (isAuthenticated() && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants']));
      
      // Delete: only DMs
      allow delete: if isDM();
    }
  }
}
